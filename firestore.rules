rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper functions
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isValidAmount(amount) {
      return amount is number && amount > 0 && amount <= 1000000000;
    }

    function isValidString(str, minLength, maxLength) {
      return str is string && str.size() >= minLength && str.size() <= maxLength;
    }

    // Helper: validate optional installment fields on transactions
    function hasValidInstallments(data) {
      // If no installments field, it's a regular transaction — valid
      return !('installments' in data.keys()) || (
        data.installments is int
        && data.installments >= 1
        && data.installments <= 36
      );
    }

    function hasValidInterestFields(data) {
      // Optional fields: only validate if present
      return (!('totalInterestAmount' in data.keys()) || (data.totalInterestAmount is number && data.totalInterestAmount >= 0))
        && (!('monthlyInstallmentAmount' in data.keys()) || (data.monthlyInstallmentAmount is number && data.monthlyInstallmentAmount > 0))
        && (!('interestRate' in data.keys()) || (data.interestRate is number && data.interestRate >= 0 && data.interestRate <= 200));
    }

    // Helper: validate optional multi-currency fields on transactions
    function hasValidCurrencyFields(data) {
      return (!('currency' in data.keys()) || data.currency is string)
        && (!('originalCurrency' in data.keys()) || data.originalCurrency is string)
        && (!('originalAmount' in data.keys()) || (data.originalAmount is number && data.originalAmount > 0))
        && (!('exchangeRate' in data.keys()) || (data.exchangeRate is number && data.exchangeRate > 0));
    }

    // User data collections
    match /users/{userId} {
      // Only authenticated users can read/write their own data
      allow read, write: if isOwner(userId);

      // Transactions subcollection
      match /transactions/{transactionId} {
        allow read: if isOwner(userId);

        // Description is optional but if provided must be valid
        allow create: if isOwner(userId)
          && request.resource.data.type in ['income', 'expense', 'transfer']
          && isValidAmount(request.resource.data.amount)
          && request.resource.data.description is string
          && request.resource.data.description.size() <= 500
          && request.resource.data.category is string
          && request.resource.data.paid is bool
          && request.resource.data.accountId is string
          && request.resource.data.date is timestamp
          && request.resource.data.createdAt is timestamp
          && hasValidInstallments(request.resource.data)
          && hasValidInterestFields(request.resource.data)
          && hasValidCurrencyFields(request.resource.data);

        // AUDIT-FIX (#30): update endurecido para espejar la validación de create.
        // La app hace updates PARCIALES (togglear paid, editar amount/date/category/
        // description, mover accountId en merge de TC, sincronizar cuotas/intereses).
        // Como Firestore fusiona, request.resource.data SIEMPRE contiene el doc
        // completo, así que validar los campos siempre presentes no rompe updates
        // parciales: los campos no tocados conservan su valor previo (ya válido).
        // Reglas:
        //  - type es inmutable (no se puede cambiar income/expense/transfer).
        //  - accountId string (puede cambiar en merge de TC).
        //  - amount number > 0 y dentro de rango (isValidAmount).
        //  - description string <= 500 (se permite vacía intencionalmente, fix #17).
        //  - category string (igual que create: no exige no-vacío para no bloquear
        //    docs heredados ni los updates parciales que no tocan category).
        //  - date timestamp.
        //  - paid bool.
        //  - cuotas, intereses y multimoneda: si están presentes, dentro de rango.
        allow update: if isOwner(userId)
          && request.resource.data.type == resource.data.type
          && request.resource.data.accountId is string
          && isValidAmount(request.resource.data.amount)
          && request.resource.data.description is string
          && request.resource.data.description.size() <= 500
          && request.resource.data.category is string
          && request.resource.data.date is timestamp
          && request.resource.data.paid is bool
          && hasValidInstallments(request.resource.data)
          && hasValidInterestFields(request.resource.data)
          && hasValidCurrencyFields(request.resource.data);

        allow delete: if isOwner(userId);
      }

      // Accounts subcollection
      match /accounts/{accountId} {
        allow read: if isOwner(userId);

        allow create: if isOwner(userId)
          && request.resource.data.name is string
          && request.resource.data.name.size() > 0
          && request.resource.data.type in ['savings', 'credit', 'cash']
          && request.resource.data.isDefault is bool
          && request.resource.data.initialBalance is number
          && request.resource.data.initialBalance >= -1000000000
          && request.resource.data.initialBalance <= 1000000000;

        // AUDIT-FIX: update valida que type sea inmutable y name sea válido
        allow update: if isOwner(userId)
          && request.resource.data.type == resource.data.type
          && request.resource.data.name is string
          && request.resource.data.name.size() > 0;

        allow delete: if isOwner(userId);
      }

      // Categories subcollection
      match /categories/{categoryId} {
        allow read: if isOwner(userId);

        allow create: if isOwner(userId)
          && request.resource.data.type in ['expense', 'income']
          && request.resource.data.name is string
          && request.resource.data.name.size() > 0
          && request.resource.data.name.size() <= 100;

        // AUDIT-FIX (#30): update endurecido (espeja create). La app actual solo
        // crea/borra categorías, pero validamos por si un restore/import escribe.
        //  - type inmutable y dentro del enum.
        //  - name string no vacío y <= 100.
        allow update: if isOwner(userId)
          && request.resource.data.type == resource.data.type
          && request.resource.data.type in ['expense', 'income']
          && request.resource.data.name is string
          && request.resource.data.name.size() > 0
          && request.resource.data.name.size() <= 100;
        allow delete: if isOwner(userId);
      }

      // Recurring payments subcollection
      match /recurringPayments/{paymentId} {
        allow read: if isOwner(userId);

        allow create: if isOwner(userId)
          && request.resource.data.name is string
          && request.resource.data.name.size() > 0
          && request.resource.data.name.size() <= 200
          && isValidAmount(request.resource.data.amount)
          && request.resource.data.category is string
          && request.resource.data.dueDay is int
          && request.resource.data.dueDay >= 1
          && request.resource.data.dueDay <= 31
          && request.resource.data.frequency in ['monthly', 'yearly']
          && request.resource.data.isActive is bool
          && request.resource.data.createdAt is timestamp;

        // AUDIT-FIX (#30): update endurecido (espeja create). La app hace updates
        // PARCIALES: { isActive } (pausar/reactivar), { amount } (sincronizar con
        // el pago real), edición completa por formulario, y al registrar un pago
        // puede fijar lastPaidDate / lastPaidAmount. Firestore fusiona, así que
        // request.resource.data tiene el doc completo: validar los campos siempre
        // presentes no rompe los updates parciales.
        //  - name string 1-200.
        //  - amount number > 0 y en rango (isValidAmount).
        //  - category string.
        //  - dueDay int 1-31.
        //  - frequency en ['monthly','yearly'].
        //  - isActive bool.
        //  - lastPaidDate (opcional): si está, timestamp.
        //  - lastPaidAmount (opcional): si está, number >= 0.
        allow update: if isOwner(userId)
          && request.resource.data.name is string
          && request.resource.data.name.size() > 0
          && request.resource.data.name.size() <= 200
          && isValidAmount(request.resource.data.amount)
          && request.resource.data.category is string
          && request.resource.data.dueDay is int
          && request.resource.data.dueDay >= 1
          && request.resource.data.dueDay <= 31
          && request.resource.data.frequency in ['monthly', 'yearly']
          && request.resource.data.isActive is bool
          && (!('lastPaidDate' in request.resource.data.keys())
              || request.resource.data.lastPaidDate is timestamp)
          && (!('lastPaidAmount' in request.resource.data.keys())
              || (request.resource.data.lastPaidAmount is number
                  && request.resource.data.lastPaidAmount >= 0));
        allow delete: if isOwner(userId);
      }

      // Debts / Loans subcollection
      match /debts/{debtId} {
        allow read: if isOwner(userId);

        allow create: if isOwner(userId)
          && request.resource.data.personName is string
          && request.resource.data.personName.size() > 0
          && request.resource.data.personName.size() <= 200
          && request.resource.data.type in ['lent', 'borrowed']
          && isValidAmount(request.resource.data.originalAmount)
          && request.resource.data.remainingAmount is number
          && request.resource.data.remainingAmount >= 0
          && request.resource.data.remainingAmount <= request.resource.data.originalAmount
          && request.resource.data.isSettled is bool
          && request.resource.data.createdAt is timestamp;

        allow update: if isOwner(userId)
          && request.resource.data.type == resource.data.type
          && request.resource.data.personName is string
          && request.resource.data.personName.size() > 0
          && isValidAmount(request.resource.data.originalAmount)
          && request.resource.data.remainingAmount is number
          && request.resource.data.remainingAmount >= 0
          && request.resource.data.remainingAmount <= request.resource.data.originalAmount;

        allow delete: if isOwner(userId);
      }

      // Budgets subcollection
      match /budgets/{budgetId} {
        allow read: if isOwner(userId);

        allow create: if isOwner(userId)
          && request.resource.data.category is string
          && request.resource.data.category.size() > 0
          && request.resource.data.category.size() <= 100
          && isValidAmount(request.resource.data.monthlyLimit)
          && request.resource.data.isActive is bool
          && request.resource.data.createdAt is timestamp;

        allow update: if isOwner(userId)
          && request.resource.data.category is string
          && request.resource.data.category.size() > 0;

        allow delete: if isOwner(userId);
      }

      // Savings Goals subcollection
      match /savingsGoals/{goalId} {
        allow read: if isOwner(userId);

        allow create: if isOwner(userId)
          && request.resource.data.name is string
          && request.resource.data.name.size() > 0
          && request.resource.data.name.size() <= 200
          && isValidAmount(request.resource.data.targetAmount)
          && request.resource.data.currentAmount is number
          && request.resource.data.currentAmount >= 0
          && request.resource.data.isCompleted is bool
          && request.resource.data.createdAt is timestamp;

        allow update: if isOwner(userId)
          && request.resource.data.name is string
          && request.resource.data.name.size() > 0
          && request.resource.data.currentAmount is number
          && request.resource.data.currentAmount >= 0;

        allow delete: if isOwner(userId);
      }

      // Notifications subcollection
      match /notifications/{notificationId} {
        allow read: if isOwner(userId);

        allow create: if isOwner(userId)
          && request.resource.data.type in ['budget', 'recurring', 'unusual_spending', 'low_balance', 'debt', 'info']
          && request.resource.data.title is string
          && request.resource.data.title.size() > 0
          && request.resource.data.title.size() <= 200
          && request.resource.data.message is string
          && request.resource.data.message.size() > 0
          && request.resource.data.message.size() <= 500
          && request.resource.data.severity in ['info', 'warning', 'error', 'success']
          && request.resource.data.isRead is bool
          && request.resource.data.createdAt is timestamp;

        // AUDIT-FIX (#30): update endurecido (espeja create). En la práctica la app
        // solo hace { isRead: true } (marcar leída / marcar todas como leídas).
        // Firestore fusiona, así que request.resource.data tiene el doc completo;
        // validamos los campos siempre presentes sin romper el update parcial.
        //  - type inmutable y dentro del enum.
        //  - title string 1-200.
        //  - message string 1-500.
        //  - severity en el enum permitido.
        //  - isRead bool.
        allow update: if isOwner(userId)
          && request.resource.data.type == resource.data.type
          && request.resource.data.type in ['budget', 'recurring', 'unusual_spending', 'low_balance', 'debt', 'info']
          && request.resource.data.title is string
          && request.resource.data.title.size() > 0
          && request.resource.data.title.size() <= 200
          && request.resource.data.message is string
          && request.resource.data.message.size() > 0
          && request.resource.data.message.size() <= 500
          && request.resource.data.severity in ['info', 'warning', 'error', 'success']
          && request.resource.data.isRead is bool;
        allow delete: if isOwner(userId);
      }

      // Notification Preferences document
      match /notificationPreferences/settings {
        allow read: if isOwner(userId);
        allow write: if isOwner(userId);
      }

      // Ajustes del usuario (incluye la API key de Gemini en modo BYOK y el
      // consentimiento de IA). Solo el dueño lee/escribe; geminiApiKey, si está,
      // debe ser string; aiConsent, si está, debe ser bool.
      match /settings/{settingId} {
        allow read: if isOwner(userId);
        allow write: if isOwner(userId)
          && (!('geminiApiKey' in request.resource.data.keys())
              || request.resource.data.geminiApiKey is string)
          && (!('aiConsent' in request.resource.data.keys())
              || request.resource.data.aiConsent is bool);
      }
    }

    // Deny all other access
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
